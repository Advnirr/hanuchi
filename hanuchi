class ConfigManager:
    @staticmethod
    def load():
        if not os.path.exists(CONFIG_DIR):
            os.makedirs(CONFIG_DIR, exist_ok=True)
        if not os.path.exists(CONFIG_FILE):
            sys_lang = "en"
            try:
                loc = locale.getdefaultlocale()[0]
                if loc and "ru" in loc.lower():
                    sys_lang = "ru"
            except: pass
            default_conf = {"language": sys_lang}
            ConfigManager.save(default_conf)
            return default_conf
        try:
            with open(CONFIG_FILE, 'r') as f:
                return json.load(f)
        except:
            return {"language": "en"}

    @staticmethod
    def save(conf):
        try:
            with open(CONFIG_FILE, 'w') as f:
                json.dump(conf, f)
        except: pass

CURRENT_CONFIG = ConfigManager.load()
LANG_CODE = CURRENT_CONFIG.get("language", "en")
if LANG_CODE not in TRANSLATIONS: LANG_CODE = "en"

def tr(key):
    return TRANSLATIONS[LANG_CODE].get(key, key)

def log(msg):
    print(f"[Hanuchi] {msg}", flush=True)

class HamachiBackend:
    @staticmethod
    def _run_hamachi(args):
        paths = ["/usr/bin/hamachi", "/opt/logmein-hamachi/bin/hamachi", "hamachi"]
        exe = None
        for p in paths:
            if os.path.exists(p) and os.access(p, os.X_OK):
                exe = p
                break
        if not exe: exe = "hamachi"
        cmd = [exe] + args
        log(f"Exec: {' '.join(cmd)}")
        try:
            result = subprocess.run(cmd, capture_output=True, text=True)
            return result.stdout
        except Exception as e:
            log(f"CRITICAL EXEC ERROR: {e}")
            return ""

    @staticmethod
    def get_self_info():
        raw = HamachiBackend._run_hamachi([])
        if not raw or "does not seem to be running" in raw: return {}
        info = {}
        for line in raw.split('\n'):
            if ':' in line:
                key, val = line.split(':', 1)
                info[key.strip().lower()] = val.strip()
        return info

    @staticmethod
    def start_daemon_pkexec():
        log("Attempting to start daemon via pkexec...")
        try:
            subprocess.run(["pkexec", "systemctl", "start", "logmein-hamachi"], check=True)
            time.sleep(2) 
            return True
        except subprocess.CalledProcessError:
            log("Failed to start daemon via pkexec (user cancelled or error)")
            return False

    @staticmethod
    def get_networks():
        raw = HamachiBackend._run_hamachi(['list'])
        if not raw: return []
        networks = []
        lines = raw.split('\n')
        current_net = None
        for line in lines:
            line = line.strip()
            if not line: continue
            if '[' in line and 'capacity' in line:
                try:
                    parts_bracket = line.split(']')
                    net_id = parts_bracket[0].split('[')[-1].strip()
                    right_part = parts_bracket[1]
                    cap_split = right_part.split('capacity:')
                    net_name = cap_split[0].strip() or net_id
                    rest = cap_split[1]
                    capacity = rest.split(',')[0].strip()
                    status = "Ready"
                    if "status:" in rest:
                        status = rest.split('status:')[1].split(',')[0].strip()
                    elif "owner" in rest:
                        status = "Hosted"
                    current_net = {'id': net_id, 'name': net_name, 'capacity': capacity, 'status': status, 'members': []}
                    networks.append(current_net)
                    continue
                except: pass
            if current_net is not None and ("25." in line or "2620:" in line):
                parts = line.split()
                if len(parts) >= 3:
                    ip = next((p for p in parts if p.startswith("25.") or p.startswith("2620:")), "Unknown")
                    alias = parts[2] if len(parts) > 2 else "Unknown"
                    current_net['members'].append({'id': 'N/A', 'alias': alias, 'ip': ip})
        return networks

    @staticmethod
    def run_cmd_bg(cmd):
        HamachiBackend._run_hamachi([cmd])
    @staticmethod
    def join_network(nid, pw):
        args = ['join', nid]
        if pw: args.append(pw)
        return HamachiBackend._run_hamachi(args)
    @staticmethod
    def create_network(nid, pw):
        args = ['create', nid]
        if pw: args.append(pw)
        return HamachiBackend._run_hamachi(args)
    @staticmethod
    def leave_network(nid):
        return HamachiBackend._run_hamachi(['leave', nid])
    @staticmethod
    def delete_network(nid):
        return HamachiBackend._run_hamachi(['delete', nid])

class SettingsDialog(Gtk.Window):
    def __init__(self, parent):
        super().__init__(transient_for=parent, modal=True, title=tr("settings"))
        self.set_default_size(300, 200)
        self.set_resizable(False)
        
        box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=12)
        box.set_margin_top(20); box.set_margin_bottom(20); box.set_margin_start(20); box.set_margin_end(20)
        self.set_child(box)

        lbl = Gtk.Label(label=tr("language"), xalign=0)
        lbl.add_css_class("heading")
        box.append(lbl)

        self.combo = Gtk.ComboBoxText()
        self.combo.append("en", "English")
        self.combo.append("ru", "Русский")
        self.combo.set_active_id(LANG_CODE)
        self.combo.connect("changed", self.on_change)
        box.append(self.combo)

        self.info_lbl = Gtk.Label(label="")
        self.info_lbl.set_wrap(True)
        self.info_lbl.add_css_class("dim-label")
        box.append(self.info_lbl)

    def on_change(self, combo):
        new_lang = combo.get_active_id()
        if new_lang != LANG_CODE:
            cfg = ConfigManager.load()
            cfg["language"] = new_lang
            ConfigManager.save(cfg)
            self.info_lbl.set_label(tr("restart_msg"))

class NetworkDialog(Gtk.Window):
    def __init__(self, parent, action_name, action_code, callback):
        super().__init__(transient_for=parent, modal=True, title=action_name)
        self.set_default_size(300, 180)
        self.set_resizable(False)
        self.callback = callback
        box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=12)
        box.set_margin_top(20); box.set_margin_bottom(20); box.set_margin_start(20); box.set_margin_end(20)
        self.set_child(box)
        self.id_entry = Gtk.Entry(placeholder_text=tr("id"))
        self.pass_entry = Gtk.Entry(placeholder_text=tr("pass_opt")); self.pass_entry.set_visibility(False)
        box.append(Gtk.Label(label=tr("id"), xalign=0)); box.append(self.id_entry)
        box.append(Gtk.Label(label="Password", xalign=0)); box.append(self.pass_entry)
        btn_box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=10); btn_box.set_halign(Gtk.Align.END)
        do_btn = Gtk.Button(label=action_code); do_btn.add_css_class("suggested-action")
        do_btn.connect("clicked", lambda x: self.on_confirm())
        btn_box.append(do_btn); box.append(btn_box)
    def on_confirm(self):
        if self.id_entry.get_text():
            self.callback(self.id_entry.get_text(), self.pass_entry.get_text())
            self.destroy()

class HanuchiWindow(Adw.ApplicationWindow):
    def __init__(self, app):
        super().__init__(application=app, title=tr("title"))
        self.set_default_size(860, 580)
        self.set_resizable(False)
        self.set_icon_name("hanuchi")
        self.auto_start_attempted = False

